{
  "expo": {
    "name": "NeuBridge",
    "slug": "neubridge",
    "scheme": "neubridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2A4A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hawkinsempire.neubridge",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NeuBridge needs your location for the emergency SOS feature to send your position to caregivers.",
        "NSMicrophoneUsageDescription": "NeuBridge uses the microphone for voice-based spelling exercises and voice message recording.",
        "NSCameraUsageDescription": "NeuBridge uses the camera to let caregivers upload photos for reminiscence therapy.",
        "NSPhotoLibraryUsageDescription": "NeuBridge accesses photos for the family photo album and pet memorialization features."
      }
    },
    "android": {
      "package": "com.hawkinsempire.neubridge",
      "versionCode": 1,
      "permissions": ["ACCESS_FINE_LOCATION", "RECORD_AUDIO", "CAMERA", "READ_EXTERNAL_STORAGE"],
      "adaptiveIcon": {
        "backgroundColor": "#1B2A4A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "PLACEHOLDER_EAS_PROJECT_ID"
      }
    }
  }
}
